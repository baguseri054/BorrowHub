<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Kotak Pencarian -->
    <LinearLayout
        android:id="@+id/searchContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="16dp"
        android:background="@drawable/bg_search_bar"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#6C757D" />

        <EditText
            android:id="@+id/etSearchLoan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@null"
            android:hint="Search active loans..."
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Daftar Peminjaman Aktif -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvActiveLoans"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnNewLoan"
        android:layout_below="@id/searchContainer"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

    <!-- Tombol Tambah Peminjaman Baru -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNewLoan"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:backgroundTint="#0056C6"
        android:text="New Loan"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

</RelativeLayout>